#!/usr/bin/env python3
import sys
import subprocess
import fcntl
import time
import os

def main():
    # Basic flock implementation for macOS
    # Usage: flock [-w timeout] <lockfile_fd> <command> [args...]
    # Or: flock [-w timeout] <lockfile_path> <command> [args...]
    
    args = sys.argv[1:]
    timeout = None
    if "-w" in args:
        idx = args.index("-w")
        timeout = float(args[idx+1])
        args = args[:idx] + args[idx+2:]
        
    if len(args) < 2:
        print("Usage: flock [-w timeout] <fd_or_path> <command> [args...]")
        sys.exit(1)
        
    target = args[0]
    command = args[1:]
    
    fd = None
    try:
        if target.isdigit():
            fd = int(target)
        else:
            fd = os.open(target, os.O_RDWR | os.O_CREAT, 0o666)
            
        start_time = time.time()
        while True:
            try:
                fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
                break
            except (IOError, OSError):
                if timeout is not None and (time.time() - start_time) > timeout:
                    sys.exit(1)
                time.sleep(0.1)
                
        # Run the command
        if command:
            res = subprocess.run(command)
            sys.exit(res.return_code)
        else:
            # If no command, just hold the lock (not standard but sometimes used)
            sys.exit(0)
            
    except Exception as e:
        print(f"flock: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
