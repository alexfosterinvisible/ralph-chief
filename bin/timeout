#!/usr/bin/env python3
import sys
import subprocess
import time

def main():
    if len(sys.argv) < 3:
        print("Usage: timeout <seconds> <command> [args...]")
        sys.exit(1)

    try:
        timeout_sec = float(sys.argv[1])
    except ValueError:
        print(f"timeout: invalid time interval '{sys.argv[1]}'")
        sys.exit(125)

    command = sys.argv[2:]

    try:
        proc = subprocess.Popen(command)
        try:
            return_code = proc.wait(timeout=timeout_sec)
            sys.exit(return_code)
        except subprocess.TimeoutExpired:
            proc.terminate()
            # Give it a moment to terminate gracefully
            for _ in range(10):
                if proc.poll() is not None:
                    break
                time.sleep(0.1)
            if proc.poll() is None:
                proc.kill()
            sys.exit(124)  # Standard Exit code for timeout
    except FileNotFoundError:
        print(f"timeout: {command[0]}: command not found")
        sys.exit(127)
    except Exception as e:
        print(f"timeout: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
