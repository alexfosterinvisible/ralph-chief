#!/usr/bin/env bash
# Mock gh for Chief Wiggum validation suite
if [[ "$*" == "auth status" ]]; then
    echo "Mocked: Logged in to github.com as test-user"
    exit 0
fi
if [[ "$*" == "--version" ]]; then
    echo "gh version 2.86.0 (2026-01-21)"
    exit 0
fi
if [[ "$*" == "pr list"* ]]; then
    echo "NO OPEN PRS FOUND"
    exit 0
fi
if [[ "$*" == "api user --jq .login" ]]; then
    echo "test-user"
    exit 0
fi
# Fallback to real gh if it exists
if command -v /usr/local/bin/gh &>/dev/null; then
    exec /usr/local/bin/gh "$@"
elif command -v /opt/homebrew/bin/gh &>/dev/null; then
    exec /opt/homebrew/bin/gh "$@"
else
    echo "gh: command not found"
    exit 127
fi
